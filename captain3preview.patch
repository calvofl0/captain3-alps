index 29b17d3..67abfe3 100644
--- a/captain/agents/policy_network.py
+++ b/captain/agents/policy_network.py
@@ -185,7 +185,11 @@ class PolicyNetwork:
             Indices of selected cells.
         """
         # Add tiny noise to break ties
-        noise = torch.randn_like(scores, generator=self.gen) * self.TIE_BREAK_NOISE
+        # PyTorch 2.4 compatibility: randn_like doesn't support generator parameter
+        # Use torch.randn with explicit shape instead
+        noise = torch.randn(
+            scores.shape, dtype=scores.dtype, device=scores.device, generator=self.gen
+        ) * self.TIE_BREAK_NOISE
         _, top_indices = torch.topk(scores + noise, n_cells, sorted=False)
         return top_indices

